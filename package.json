{
  "name": "tepuledia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "lumis serve",
    "build": "pnpm run build:css && pnpm run build:node",
    "build:css": "tailwindcss -i src/shared/ui/assets/input.css -o src/shared/ui/assets/style.css --minify",
    "dev:css": "tailwindcss -i src/shared/ui/assets/input.css -o src/shared/ui/assets/style.css --watch",
    "build:node": "esbuild bootstrap/entry.ts --bundle --platform=node --target=node20 --format=esm --outfile=.arc/node/app.js --packages=external --tsconfig=tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src bootstrap --ext .ts",
    "tc": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"bootstrap/**/*.ts\""
  },
  "dependencies": {
    "@illumiarq/adapters": "^1.1.1",
    "@lumiarq/framework": "^1.0.1",
    "@trazze/ignite": "^0.1.0",
    "drizzle-orm": "0.38.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@illumiarq/lumis": "^1.2.0",
    "@lumiarq/prettier-plugin-veil": "^1.0.0",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^1.4.0",
    "esbuild": "^0.25.0",
    "prettier": "^3.7.4",
    "tailwindcss": "4.2.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "argon2"]
  }
}
