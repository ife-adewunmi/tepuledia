import { definePolicy } from '@lumiarq/framework';
import type { AuthContext } from '@/shared/contracts/auth';

/**
 * {{ClassName}} policy — governs access control for {{ClassName}} resources.
 * Define abilities as methods on the policy object.
 */
export const {{ClassName}}Policy = definePolicy<AuthContext, unknown>({
  view: (user) => Boolean(user),
  create: (user) => Boolean(user),
  update: (user, resource) => Boolean(user && user.id === resource.ownerId),
  delete: (user, resource) => Boolean(user && user.id === resource.ownerId),
});
