{
  "name": "@lumiarq/generator",
  "version": "1.0.1",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@lumiarq/context": "1.0.1",
    "@lumiarq/planner": "1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts"
  }
}