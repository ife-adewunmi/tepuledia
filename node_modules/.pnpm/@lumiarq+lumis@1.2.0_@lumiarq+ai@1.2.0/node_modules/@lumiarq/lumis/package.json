{
  "name": "@lumiarq/lumis",
  "version": "1.2.0",
  "license": "MIT",
  "description": "Lumis — multi-pack AI coding agent CLI",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "lumis": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "publish:dry-run": "node scripts/publish.mjs",
    "publish:all": "node scripts/publish.mjs --publish"
  },
  "dependencies": {
    "@lumiarq/agent": "workspace:*",
    "@lumiarq/context": "workspace:*",
    "@lumiarq/generator": "workspace:*",
    "@lumiarq/pack-lumiarq": "workspace:*",
    "@lumiarq/pack-nextjs": "workspace:*",
    "@lumiarq/pack-django": "workspace:*",
    "@lumiarq/pack-laravel": "workspace:*",
    "@lumiarq/planner": "workspace:*",
    "@lumiarq/rag": "workspace:*",
    "@lumiarq/tinker": "workspace:*",
    "@lumiarq/verifier": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.23.0",
    "turbo": "^2.3.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.0"
}
