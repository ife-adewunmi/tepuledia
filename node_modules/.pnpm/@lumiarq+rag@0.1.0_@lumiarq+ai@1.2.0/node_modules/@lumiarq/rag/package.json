{
  "name": "@lumiarq/rag",
  "version": "0.1.0",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "description": "Framework-agnostic RAG runtime. Ingest, chunk, embed, retrieve, rerank, and answer with citations. Zero lock-in.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@lumiarq/ai": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@lumiarq/ai": { "optional": true }
  }
}
