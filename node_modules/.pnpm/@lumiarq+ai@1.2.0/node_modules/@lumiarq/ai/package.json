{
  "name": "@lumiarq/ai",
  "version": "1.2.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Framework-agnostic AI provider gateway. Zero platform lock-in, zero dependencies. Supports OpenAI, Anthropic, Gemini, Groq, and custom providers.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts"
  }
}