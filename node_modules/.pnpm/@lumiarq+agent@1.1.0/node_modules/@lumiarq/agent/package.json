{
  "name": "@lumiarq/agent",
  "version": "1.1.0",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "type": "module",
  "description": "Provider-agnostic AI gateway for intent parsing, plan proposal, and token suggestion. Zero platform lock-in.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "SDK.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {
    "@lumiarq/ai": "workspace:^1.1.0",
    "@lumiarq/context": "workspace:*",
    "@lumiarq/planner": "workspace:*",
    "@lumiarq/generator": "workspace:*",
    "@lumiarq/verifier": "workspace:*",
    "@lumiarq/rag": "workspace:^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
