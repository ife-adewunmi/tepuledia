# ── Tepuledia environment ──────────────────────────────────────────────────────

NODE_ENV=development
APP_ENV=local
APP_NAME=Tepuledia
APP_URL=http://localhost:3000

# ── Database ───────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
DATABASE_URL=file:./src/shared/database/database.sqlite

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# Run: pnpm lumis key:generate  — fills these three values automatically
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
SESSION_SECRET=

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_DRIVER=stub
MAIL_FROM_ADDRESS=noreply@tepuledia.com
MAIL_FROM_NAME=Tepuledia

# ── Queue ──────────────────────────────────────────────────────────────────────
QUEUE_DRIVER=stub

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_DRIVER=memory
